#!/usr/bin/env sh
# pre-push hook: run the local push smoke before pushing.
# Delegates to just gate-push by default, just gate-fast with CAMP_GATE_FAST=1,
# or just gate with CAMP_GATE_FULL=1.
# githooks(5): stdin carries <local-ref> <local-sha> <remote-ref> <remote-sha> per pushed ref.
# Must consume stdin even if unused to satisfy the protocol.

# Consume stdin per githooks(5) pre-push contract.
cat > /dev/null

# Git hooks run with repository-local GIT_* variables set. The gate runs tests
# that create and mutate temporary git repos, so those variables must not leak
# into child git commands.
if local_env_vars=$(git rev-parse --local-env-vars 2>/dev/null); then
    unset $local_env_vars
fi

if [ "${CAMP_GATE_FULL:-0}" = "1" ]; then
    gate_cmd="just gate"
elif [ "${CAMP_GATE_FAST:-0}" = "1" ]; then
    gate_cmd="just gate-fast"
else
    gate_cmd="just gate-push"
fi

if ! $gate_cmd; then
    echo ""
    echo "========================================================"
    echo "  PRE-PUSH GATE FAILED"
    echo "  Reproduce locally: $gate_cmd"
    echo "  Skip (discouraged): git push --no-verify"
    echo "========================================================"
    exit 1
fi
